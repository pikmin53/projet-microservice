# BDD user
POSTGRES_USER_USER=user
POSTGRES_USER_PASSWORD=password
POSTGRES_USER_DB=user_db
# BDD tensorflow
POSTGRES_TENSORFLOW_USER=user
POSTGRES_TENSORFLOW_PASSWORD=password
POSTGRES_TENSORFLOW_DB=tensorflow_db
# BDD pytorch
POSTGRES_PYTORCH_USER=user
POSTGRES_PYTORCH_PASSWORD=password
POSTGRES_PYTORCH_DB=pytorch_db

PORT_API=8000
PORT_AUTH=8001
PORT_BDD=5432
PORT_ADMINER=8080
PORT_FRONT=5173
PORT_TENSORFLOW=8003
PORT_PYTORCH=8002
PORT_KAFKA=9092

VITE_API_GATEWAY_URL=http://localhost:${PORT_API}
VITE_API_AUTH_URL=http://localhost:${PORT_AUTH}

API_AUTH_URL=http://service_auth:${PORT_AUTH}

SECRET_KEY=your_secret_key
ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30
DATABASE_USER_URL=postgresql://${POSTGRES_USER_USER}:${POSTGRES_USER_PASSWORD}@user_db:${PORT_BDD}/${POSTGRES_USER_DB}
DATABASE_TENSORFLOW_URL=postgresql://${POSTGRES_TENSORFLOW_USER}:${POSTGRES_TENSORFLOW_PASSWORD}@tensorflow_db:${PORT_BDD}/${POSTGRES_TENSORFLOW_DB}
DATABASE_PYTORCH_URL=postgresql://${POSTGRES_PYTORCH_USER}:${POSTGRES_PYTORCH_PASSWORD}@pytorch_db:${PORT_BDD}/${POSTGRES_PYTORCH_DB}